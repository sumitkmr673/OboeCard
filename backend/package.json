{
	"name": "flashcard-backend",
	"version": "1.0.0",
	"description": "Express API backend for Flashcard Platform",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"dev": "node --loader ts-node/esm --watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"lint": "eslint src/**/*.ts",
		"type-check": "tsc --noEmit",
		"prisma:migrate": "prisma migrate dev",
		"prisma:generate": "prisma generate",
		"prisma:push": "prisma db push",
		"prisma:seed": "node --loader ts-node/esm prisma/seed.ts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@prisma/client": "^5.14.0",
		"bcrypt": "^5.1.1",
		"bullmq": "^5.7.0",
		"compression": "^1.7.4",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^5.2.1",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"morgan": "^1.10.0",
		"redis": "^4.6.13",
		"typescript": "^6.0.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.11",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/node": "^22.0.0",
		"jest": "^29.7.0",
		"prisma": "^5.14.0",
		"ts-node": "^10.9.2",
		"typescript-eslint": "^7.0.0"
	}
}
